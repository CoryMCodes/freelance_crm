<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold text-gray-900 mb-8">Welcome to Freelance CRM</h1>
    
    <div class="bg-white shadow-lg rounded-lg p-6 mb-6">
      <h2 class="text-2xl font-semibold text-gray-800 mb-4">Hello, <%= current_user.email %></h2>
      <p class="text-gray-600 mb-4">Manage your clients, projects, and invoices all in one place.</p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <%= link_to clients_path, class: "bg-blue-50 p-4 rounded-lg hover:bg-blue-100 transition-colors" do %>
          <h3 class="font-semibold text-blue-800">Clients</h3>
          <p class="text-sm text-blue-600">Manage your client relationships</p>
        <% end %>
        <div class="bg-green-50 p-4 rounded-lg">
          <h3 class="font-semibold text-green-800">Projects</h3>
          <p class="text-sm text-green-600">Track project progress and tasks</p>
        </div>
        <div class="bg-purple-50 p-4 rounded-lg">
          <h3 class="font-semibold text-purple-800">Invoices</h3>
          <p class="text-sm text-purple-600">Create and manage invoices</p>
        </div>
      </div>
    </div>
  </div>
</div>
