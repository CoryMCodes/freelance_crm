<div class="container mx-auto px-4 py-8">
  <div class="max-w-4xl mx-auto">
    <div class="flex justify-between items-start mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900"><%= @client.name %></h1>
        <p class="text-gray-600 mt-1"><%= @client.company %></p>
      </div>
      <div class="flex space-x-3">
        <%= link_to "Edit", edit_client_path(@client), 
            class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors" %>
        <%= link_to "Back to Clients", clients_path, 
            class: "bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg transition-colors" %>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Client Details -->
      <div class="lg:col-span-1">
        <div class="bg-white rounded-lg shadow-md p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Contact Information</h2>
          
          <div class="space-y-4">
            <div>
              <label class="text-sm font-medium text-gray-500">Email</label>
              <p class="text-gray-900"><%= @client.email %></p>
            </div>
            
            <% if @client.phone.present? %>
              <div>
                <label class="text-sm font-medium text-gray-500">Phone</label>
                <p class="text-gray-900"><%= @client.phone %></p>
              </div>
            <% end %>
            
            <% if @client.address.present? %>
              <div>
                <label class="text-sm font-medium text-gray-500">Address</label>
                <p class="text-gray-900 whitespace-pre-line"><%= @client.address %></p>
              </div>
            <% end %>
          </div>

          <% if @client.tags.any? %>
            <div class="mt-6">
              <label class="text-sm font-medium text-gray-500 mb-2 block">Tags</label>
              <div class="flex flex-wrap gap-2">
                <% @client.tags.each do |tag| %>
                  <span class="px-3 py-1 text-sm rounded-full" 
                        style="background-color: <%= tag.color %>20; color: <%= tag.color %>;">
                    <%= tag.name %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Notes Section -->
      <div class="lg:col-span-2">
        <div class="bg-white rounded-lg shadow-md p-6">
          <h2 class="text-xl font-semibold text-gray-900 mb-4">Notes</h2>
          
          <!-- Add Note Form -->
          <%= form_with(model: [@client, @new_note], local: true, class: "mb-6") do |form| %>
            <div>
              <%= form.text_area :content, rows: 3, placeholder: "Add a note about this client...", 
                  class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-blue-500 focus:border-blue-500" %>
            </div>
            <div class="mt-3">
              <%= form.submit "Add Note", 
                  class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors" %>
            </div>
          <% end %>

          <!-- Notes List -->
          <% if @notes.any? %>
            <div class="space-y-4">
              <% @notes.each do |note| %>
                <div class="border-l-4 border-blue-500 pl-4 py-2">
                  <div class="flex justify-between items-start">
                    <p class="text-gray-900"><%= note.content %></p>
                    <%= link_to "Delete", client_note_path(@client, note), 
                        method: :delete, 
                        data: { turbo_confirm: "Are you sure?" },
                        class: "text-red-600 hover:text-red-800 text-sm ml-2" %>
                  </div>
                  <p class="text-sm text-gray-500 mt-1">
                    Added <%= time_ago_in_words(note.created_at) %> ago
                  </p>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-500 text-center py-8">No notes yet. Add your first note above.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
