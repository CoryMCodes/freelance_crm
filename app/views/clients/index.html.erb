<div class="container mx-auto px-4 py-8">
  <div class="max-w-7xl mx-auto">
    <div class="flex justify-between items-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Clients</h1>
      <%= link_to "Add New Client", new_client_path, 
          class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors" %>
    </div>

    <% if @clients.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @clients.each do |client| %>
          <div class="bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow">
            <div class="flex justify-between items-start mb-4">
              <div>
                <h3 class="text-xl font-semibold text-gray-900 mb-1">
                  <%= link_to client.name, client_path(client), class: "hover:text-blue-600" %>
                </h3>
                <p class="text-gray-600 text-sm"><%= client.company %></p>
              </div>
              <div class="flex space-x-2">
                <%= link_to "Edit", edit_client_path(client), 
                    class: "text-blue-600 hover:text-blue-800 text-sm" %>
                <%= link_to "Delete", client_path(client), 
                    method: :delete, 
                    data: { turbo_confirm: "Are you sure?" },
                    class: "text-red-600 hover:text-red-800 text-sm" %>
              </div>
            </div>
            
            <div class="space-y-2 mb-4">
              <p class="text-sm text-gray-600">
                <span class="font-medium">Email:</span> <%= client.email %>
              </p>
              <% if client.phone.present? %>
                <p class="text-sm text-gray-600">
                  <span class="font-medium">Phone:</span> <%= client.phone %>
                </p>
              <% end %>
            </div>

            <div class="mb-4" data-controller="tags" data-tags-client-id-value="<%= client.id %>">
              <div class="flex flex-wrap gap-2 mb-2" data-tags-target="list">
                <% client.tags.each do |tag| %>
                  <span class="tag-item inline-flex items-center px-2 py-1 text-xs rounded-full mr-2 mb-2" 
                        style="background-color: <%= tag.color %>20; color: <%= tag.color %>;"
                        data-tag-id="<%= tag.id %>"
                        data-tag-name="<%= tag.name %>">
                    <%= tag.name %>
                    <button data-action="click->tags#removeTag" 
                            data-tag-id="<%= tag.id %>" 
                            class="ml-1 text-xs hover:opacity-75">
                      ×
                    </button>
                  </span>
                <% end %>
              </div>
              
              <!-- Add Tag Form -->
              <div class="hidden" data-tags-target="form">
                <form action="<%= client_tags_path(client) %>" 
                      method="post" 
                      data-action="submit->tags#addTag"
                      class="flex items-center space-x-2">
                  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
                  <select name="tag_id" 
                          data-tags-target="input"
                          class="text-xs border border-gray-300 rounded px-2 py-1 focus:outline-none focus:ring-1 focus:ring-blue-500">
                    <option value="">Select a tag...</option>
                    <% current_user.tags.ordered.each do |tag| %>
                      <% unless client.tags.include?(tag) %>
                        <option value="<%= tag.id %>" 
                                style="color: <%= tag.color %>;">
                          <%= tag.name %>
                        </option>
                      <% end %>
                    <% end %>
                  </select>
                  <button type="submit" 
                          class="text-xs bg-blue-500 text-white px-2 py-1 rounded hover:bg-blue-600">
                    Add
                  </button>
                  <button type="button" 
                          data-action="click->tags#hideAddForm"
                          class="text-xs text-gray-500 hover:text-gray-700">
                    Cancel
                  </button>
                </form>
              </div>
              
              <!-- Add Tag Button -->
              <button data-action="click->tags#showAddForm"
                      class="text-xs text-blue-600 hover:text-blue-800">
                + Add Tag
              </button>
            </div>

            <div class="text-sm text-gray-500">
              <%= pluralize(client.notes.count, 'note') %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12">
        <div class="text-gray-400 mb-4">
          <svg class="mx-auto h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">No clients yet</h3>
        <p class="text-gray-500 mb-6">Get started by adding your first client.</p>
        <%= link_to "Add Your First Client", new_client_path, 
            class: "bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
